# Production environment for the Stake Affiliate API (Docker).
# Copy to .env on the server, fill the secrets, then `docker compose up -d`.

APP_NAME=Stake
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.stakeaffilates12.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Caddy site address used by FrankenPHP:
#   ":80"                       -> HTTP on any host (reachable via the server IP)
#   "api.stakeaffilates12.com"  -> automatic HTTPS (needs DNS A record -> server IP)
SERVER_NAME=api.stakeaffilates12.com

# Host ports published by docker compose.
APP_HTTP_PORT=80
APP_HTTPS_PORT=443

# CORS: the SPA is hosted separately and authenticates with bearer tokens,
# so any origin is acceptable. Restrict to your SPA URL if you prefer.
FRONTEND_URL=*

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/app/storage/app/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database

# Zoho Mail SMTP. Host depends on the mailbox type:
#   free / @zohomail.eu account -> smtp.zoho.eu
#   paid domain mailbox         -> smtppro.zoho.eu
# Port 465 = SSL -> scheme "smtps". MAIL_FROM_ADDRESS must equal the login
# (or a verified alias) or Zoho rejects the message. Password is a secret —
# keep it only here on the server, never in git.
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.zoho.eu
MAIL_PORT=465
MAIL_USERNAME=stake-affilates@zohomail.eu
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="stake-affilates@zohomail.eu"
MAIL_FROM_NAME="Stake Affiliate"
